<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <title>오타쿠 체스 ♟ 천사 vs 마계</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Gugi&family=Gothic+A1:wght@400;700;900&family=Zen+Dots&display=swap" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/chess.js@0.10.3/chess.min.js"></script>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg-main: #F5EEF8;
      --bg-card: #FFFFFF;
      --bg-card-alpha: rgba(255,255,255,0.85);
      --text-primary: #1A1028;
      --text-secondary: #6B5B7B;
      --text-muted: #9E8FB0;
      --board-light: #EDE0F5;
      --board-dark: #9B72B0;
      --board-border: #7B4F9A;
      --selected-bg: rgba(255, 215, 0, 0.55);
      --legal-dot: rgba(120, 60, 160, 0.35);
      --last-move: rgba(180, 130, 255, 0.25);
      --check-bg: rgba(255, 50, 50, 0.45);
      --accent-gold: #C8A32E;
      --accent-pink: #D94E8F;
      --accent-purple: #7B4F9A;
      --shadow-color: rgba(80, 40, 120, 0.12);
      --white-team: linear-gradient(135deg, #FFF3E0, #FFE0B2);
      --black-team: linear-gradient(135deg, #311B60, #4A1A6B);
      --white-team-text: #8B6914;
      --black-team-text: #6B3FA0;
      --modal-bg: rgba(10, 5, 20, 0.7);
    }

    .dark {
      --bg-main: #0A0815;
      --bg-card: #161225;
      --bg-card-alpha: rgba(22,18,37,0.9);
      --text-primary: #E8E0F5;
      --text-secondary: #A898C0;
      --text-muted: #6B5B80;
      --board-light: #3A2850;
      --board-dark: #1E1235;
      --board-border: #5C3D7A;
      --selected-bg: rgba(255, 215, 0, 0.35);
      --legal-dot: rgba(200, 160, 255, 0.4);
      --last-move: rgba(140, 80, 220, 0.2);
      --check-bg: rgba(255, 40, 40, 0.35);
      --accent-gold: #FFD54F;
      --accent-pink: #FF69B4;
      --accent-purple: #B388FF;
      --shadow-color: rgba(0, 0, 0, 0.4);
      --white-team: linear-gradient(135deg, #2A2040, #3A2855);
      --black-team: linear-gradient(135deg, #150820, #220E38);
      --white-team-text: #FFD54F;
      --black-team-text: #CE93D8;
      --modal-bg: rgba(5, 2, 12, 0.85);
    }

    html, body {
      width: 100%; height: 100%;
      font-family: 'Gothic A1', sans-serif;
      background: var(--bg-main);
      color: var(--text-primary);
      overflow-x: hidden;
      -webkit-tap-highlight-color: transparent;
      user-select: none;
    }

    /* ===== TITLE SCREEN ===== */
    #title-screen {
      display: flex; flex-direction: column;
      align-items: center; justify-content: center;
      min-height: 100vh; padding: 24px;
      background: var(--bg-main);
      position: relative; overflow: hidden;
    }

    .title-bg {
      position: absolute; inset: 0;
      background:
        radial-gradient(ellipse at 20% 30%, rgba(120, 50, 180, 0.15) 0%, transparent 50%),
        radial-gradient(ellipse at 80% 70%, rgba(255, 100, 150, 0.1) 0%, transparent 50%),
        radial-gradient(ellipse at 50% 50%, rgba(100, 80, 200, 0.08) 0%, transparent 70%);
    }

    .dark .title-bg {
      background:
        radial-gradient(ellipse at 20% 30%, rgba(120, 50, 180, 0.25) 0%, transparent 50%),
        radial-gradient(ellipse at 80% 70%, rgba(255, 50, 120, 0.15) 0%, transparent 50%),
        radial-gradient(ellipse at 50% 50%, rgba(60, 20, 140, 0.2) 0%, transparent 70%);
    }

    .stars {
      position: absolute; inset: 0; overflow: hidden;
    }
    .star {
      position: absolute; width: 3px; height: 3px;
      background: var(--accent-gold); border-radius: 50%;
      animation: twinkle 3s infinite ease-in-out;
    }
    .dark .star { background: #fff; }

    @keyframes twinkle {
      0%, 100% { opacity: 0.2; transform: scale(0.8); }
      50% { opacity: 1; transform: scale(1.2); }
    }

    .game-title {
      font-family: 'Gugi', cursive;
      font-size: clamp(2.4rem, 8vw, 4.2rem);
      text-align: center;
      background: linear-gradient(135deg, var(--accent-purple), var(--accent-pink), var(--accent-gold));
      -webkit-background-clip: text;
      background-clip: text;
      -webkit-text-fill-color: transparent;
      animation: titleGlow 3s ease-in-out infinite alternate;
      position: relative; z-index: 1;
      line-height: 1.3;
    }

    @keyframes titleGlow {
      0% { filter: drop-shadow(0 0 8px rgba(180, 100, 255, 0.3)); }
      100% { filter: drop-shadow(0 0 20px rgba(255, 100, 180, 0.5)); }
    }

    .title-sub {
      font-family: 'Gothic A1', sans-serif;
      font-size: clamp(0.85rem, 3vw, 1.15rem);
      color: var(--text-secondary);
      margin-top: 8px; letter-spacing: 3px;
      position: relative; z-index: 1;
    }

    .title-versus {
      display: flex; align-items: center; gap: 18px;
      margin: 32px 0;
      position: relative; z-index: 1;
    }

    .faction-preview {
      display: flex; flex-direction: column; align-items: center; gap: 8px;
    }

    .faction-icon {
      width: 72px; height: 72px; border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      font-size: 28px; font-weight: 900;
      border: 3px solid;
      animation: float 4s ease-in-out infinite;
    }

    .faction-icon.angel {
      background: linear-gradient(135deg, #FFF8E1, #FFE082);
      border-color: #FFD54F;
      color: #8B6914;
    }
    .faction-icon.demon {
      background: linear-gradient(135deg, #4A148C, #7B1FA2);
      border-color: #CE93D8;
      color: #E1BEE7;
      animation-delay: -2s;
    }

    @keyframes float {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-8px); }
    }

    .vs-text {
      font-family: 'Zen Dots', cursive;
      font-size: clamp(1.4rem, 5vw, 2.2rem);
      color: var(--accent-pink);
      text-shadow: 0 0 12px rgba(255, 100, 180, 0.4);
    }

    .faction-label {
      font-family: 'Gugi', cursive;
      font-size: clamp(0.75rem, 2.5vw, 0.95rem);
      color: var(--text-secondary);
    }

    .title-buttons {
      display: flex; flex-direction: column; gap: 14px;
      position: relative; z-index: 1;
      width: min(320px, 85vw);
    }

    .btn {
      padding: 14px 28px;
      border: 2px solid var(--accent-purple);
      border-radius: 12px;
      background: var(--bg-card);
      color: var(--text-primary);
      font-family: 'Gugi', cursive;
      font-size: 1.05rem;
      cursor: pointer;
      transition: all 0.25s ease;
      text-align: center;
      position: relative;
      overflow: hidden;
    }
    .btn::after {
      content: ''; position: absolute; inset: 0;
      background: linear-gradient(135deg, rgba(180, 100, 255, 0.08), rgba(255, 100, 180, 0.08));
      opacity: 0; transition: opacity 0.25s;
    }
    .btn:hover, .btn:active {
      border-color: var(--accent-pink);
      transform: translateY(-2px);
      box-shadow: 0 6px 20px var(--shadow-color);
    }
    .btn:hover::after, .btn:active::after { opacity: 1; }

    .btn-primary {
      background: linear-gradient(135deg, var(--accent-purple), #9B59B6);
      color: #fff;
      border-color: transparent;
    }
    .btn-primary:hover {
      background: linear-gradient(135deg, #8E44AD, #C0392B);
      border-color: transparent;
    }

    .title-credit {
      position: relative; z-index: 1;
      margin-top: 28px;
      font-size: 0.72rem;
      color: var(--text-muted);
      letter-spacing: 1px;
    }

    /* ===== GAME SCREEN ===== */
    #game-screen {
      display: none;
      flex-direction: column;
      align-items: center;
      min-height: 100vh;
      padding: 10px 8px;
      background: var(--bg-main);
      position: relative;
    }

    .game-header {
      display: flex; align-items: center; justify-content: space-between;
      width: min(95vw, 580px);
      padding: 6px 12px;
      margin-bottom: 6px;
    }

    .game-title-small {
      font-family: 'Gugi', cursive;
      font-size: 1.1rem;
      background: linear-gradient(135deg, var(--accent-purple), var(--accent-pink));
      -webkit-background-clip: text;
      background-clip: text;
      -webkit-text-fill-color: transparent;
    }

    .header-btns { display: flex; gap: 8px; }

    .btn-icon {
      width: 36px; height: 36px;
      border-radius: 8px;
      border: 1.5px solid var(--board-border);
      background: var(--bg-card);
      color: var(--text-secondary);
      font-size: 0.85rem;
      cursor: pointer;
      display: flex; align-items: center; justify-content: center;
      transition: all 0.2s;
    }
    .btn-icon:hover { background: var(--board-light); color: var(--text-primary); }

    .player-bar {
      display: flex; align-items: center; gap: 10px;
      width: min(95vw, 580px);
      padding: 8px 12px;
      border-radius: 10px;
      background: var(--bg-card);
      border: 1.5px solid transparent;
      transition: all 0.3s;
      margin: 4px 0;
      min-height: 48px;
    }
    .player-bar.active {
      border-color: var(--accent-gold);
      box-shadow: 0 0 12px rgba(255, 215, 0, 0.15);
    }
    .dark .player-bar.active {
      box-shadow: 0 0 16px rgba(255, 215, 0, 0.2);
    }

    .player-avatar {
      width: 36px; height: 36px;
      border-radius: 50%; overflow: hidden;
      border: 2px solid var(--board-border);
      flex-shrink: 0;
    }
    .player-avatar svg { width: 100%; height: 100%; }

    .player-info { flex: 1; min-width: 0; }

    .player-name {
      font-family: 'Gugi', cursive;
      font-size: 0.85rem;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .player-faction {
      font-size: 0.65rem;
      color: var(--text-muted);
    }

    .captured-row {
      display: flex; flex-wrap: wrap; gap: 2px;
      max-width: 160px;
    }
    .captured-piece {
      width: 22px; height: 22px;
      border-radius: 50%; overflow: hidden;
      opacity: 0.7;
    }
    .captured-piece svg { width: 100%; height: 100%; }

    .turn-badge {
      font-size: 0.6rem;
      padding: 2px 8px;
      border-radius: 10px;
      background: var(--accent-gold);
      color: #1A1028;
      font-weight: 700;
      white-space: nowrap;
      flex-shrink: 0;
    }
    .turn-badge.hidden { visibility: hidden; }

    /* ===== BOARD ===== */
    .board-wrap {
      position: relative;
      margin: 4px 0;
    }

    #board {
      display: grid;
      grid-template-columns: repeat(8, 1fr);
      grid-template-rows: repeat(8, 1fr);
      width: min(92vw, 520px);
      height: min(92vw, 520px);
      border: 3px solid var(--board-border);
      border-radius: 6px;
      overflow: hidden;
      box-shadow: 0 8px 32px var(--shadow-color);
    }

    .square {
      position: relative;
      display: flex; align-items: center; justify-content: center;
      cursor: pointer;
      transition: background 0.15s;
    }
    .square.light { background: var(--board-light); }
    .square.dark-sq { background: var(--board-dark); }

    .square.selected { background: var(--selected-bg) !important; }
    .square.last-move { background: var(--last-move) !important; }
    .square.check-sq { background: var(--check-bg) !important; animation: checkPulse 1s ease-in-out infinite; }

    @keyframes checkPulse {
      0%, 100% { box-shadow: inset 0 0 8px rgba(255,40,40,0.3); }
      50% { box-shadow: inset 0 0 16px rgba(255,40,40,0.6); }
    }

    .square.legal-move::after {
      content: ''; position: absolute;
      width: 28%; height: 28%;
      border-radius: 50%;
      background: var(--legal-dot);
      pointer-events: none;
    }
    .square.legal-capture::after {
      content: ''; position: absolute;
      width: 85%; height: 85%;
      border-radius: 50%;
      border: 4px solid var(--legal-dot);
      background: transparent;
      pointer-events: none;
    }

    .piece-wrap {
      width: 82%; height: 82%;
      border-radius: 50%;
      overflow: hidden;
      transition: transform 0.1s;
      position: relative;
      z-index: 2;
    }
    .piece-wrap:hover { transform: scale(1.08); }
    .piece-wrap svg { width: 100%; height: 100%; display: block; }

    .piece-wrap.capturing {
      animation: captureShake 0.3s ease-out;
    }
    @keyframes captureShake {
      0% { transform: scale(1); }
      25% { transform: scale(1.15) rotate(-5deg); }
      50% { transform: scale(0.95) rotate(3deg); }
      75% { transform: scale(1.05); }
      100% { transform: scale(1); }
    }

    .piece-wrap.placed {
      animation: piecePlace 0.25s ease-out;
    }
    @keyframes piecePlace {
      0% { transform: scale(0.5); opacity: 0.5; }
      60% { transform: scale(1.1); opacity: 1; }
      100% { transform: scale(1); }
    }

    .coord-label {
      position: absolute;
      font-size: 0.55rem;
      font-weight: 700;
      color: var(--text-muted);
      opacity: 0.5;
      pointer-events: none;
      z-index: 1;
    }
    .coord-file { bottom: 1px; right: 3px; }
    .coord-rank { top: 1px; left: 3px; }

    /* ===== STATUS BAR ===== */
    .status-bar {
      width: min(95vw, 580px);
      text-align: center;
      padding: 6px;
      font-size: 0.78rem;
      color: var(--text-secondary);
      min-height: 28px;
    }
    .status-bar .thinking {
      display: inline-flex; align-items: center; gap: 6px;
    }
    .thinking-dots span {
      display: inline-block;
      width: 5px; height: 5px;
      border-radius: 50%;
      background: var(--accent-purple);
      animation: dotBounce 1.2s ease-in-out infinite;
    }
    .thinking-dots span:nth-child(2) { animation-delay: 0.15s; }
    .thinking-dots span:nth-child(3) { animation-delay: 0.3s; }
    @keyframes dotBounce {
      0%, 80%, 100% { transform: translateY(0); }
      40% { transform: translateY(-6px); }
    }

    .game-controls {
      display: flex; gap: 8px;
      margin-top: 8px;
    }
    .btn-sm {
      padding: 8px 16px;
      border-radius: 8px;
      border: 1.5px solid var(--board-border);
      background: var(--bg-card);
      color: var(--text-secondary);
      font-family: 'Gothic A1', sans-serif;
      font-size: 0.78rem;
      cursor: pointer;
      transition: all 0.2s;
    }
    .btn-sm:hover { background: var(--board-light); color: var(--text-primary); }

    /* ===== MODALS ===== */
    .modal-overlay {
      display: none;
      position: fixed; inset: 0;
      background: var(--modal-bg);
      z-index: 100;
      align-items: center; justify-content: center;
      padding: 20px;
      backdrop-filter: blur(4px);
    }
    .modal-overlay.active { display: flex; }

    .modal-box {
      background: var(--bg-card);
      border-radius: 16px;
      padding: 28px 24px;
      text-align: center;
      max-width: 360px;
      width: 100%;
      box-shadow: 0 16px 48px var(--shadow-color);
      animation: modalIn 0.3s ease-out;
      border: 2px solid var(--board-border);
    }
    @keyframes modalIn {
      0% { opacity: 0; transform: scale(0.85) translateY(20px); }
      100% { opacity: 1; transform: scale(1) translateY(0); }
    }

    .modal-title {
      font-family: 'Gugi', cursive;
      font-size: 1.5rem;
      margin-bottom: 8px;
      background: linear-gradient(135deg, var(--accent-gold), var(--accent-pink));
      -webkit-background-clip: text;
      background-clip: text;
      -webkit-text-fill-color: transparent;
    }

    .modal-subtitle {
      font-size: 0.9rem;
      color: var(--text-secondary);
      margin-bottom: 20px;
    }

    .promotion-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 10px;
      margin: 16px 0;
    }

    .promo-option {
      display: flex; flex-direction: column;
      align-items: center; gap: 4px;
      padding: 10px 4px;
      border-radius: 10px;
      border: 2px solid var(--board-border);
      background: var(--bg-card);
      cursor: pointer;
      transition: all 0.2s;
    }
    .promo-option:hover {
      border-color: var(--accent-gold);
      transform: translateY(-3px);
      box-shadow: 0 4px 12px var(--shadow-color);
    }
    .promo-option .promo-avatar {
      width: 44px; height: 44px;
      border-radius: 50%; overflow: hidden;
    }
    .promo-option .promo-avatar svg { width: 100%; height: 100%; }
    .promo-option .promo-label {
      font-size: 0.65rem;
      color: var(--text-secondary);
    }

    .modal-buttons {
      display: flex; gap: 10px; justify-content: center;
      margin-top: 16px;
    }

    /* ===== TOOLTIP ===== */
    #char-tooltip {
      display: none;
      position: fixed;
      z-index: 90;
      background: var(--bg-card);
      border: 2px solid var(--board-border);
      border-radius: 12px;
      padding: 12px 14px;
      max-width: 200px;
      box-shadow: 0 8px 24px var(--shadow-color);
      pointer-events: none;
    }
    #char-tooltip.visible { display: block; }

    .tooltip-header {
      display: flex; align-items: center; gap: 8px;
      margin-bottom: 6px;
    }
    .tooltip-avatar {
      width: 32px; height: 32px;
      border-radius: 50%; overflow: hidden;
    }
    .tooltip-avatar svg { width: 100%; height: 100%; }
    .tooltip-name {
      font-family: 'Gugi', cursive;
      font-size: 0.9rem;
    }
    .tooltip-rarity {
      font-size: 0.6rem;
      padding: 1px 6px;
      border-radius: 6px;
      font-weight: 700;
    }
    .tooltip-rarity.SSR { background: linear-gradient(135deg, #FFD700, #FF8C00); color: #fff; }
    .tooltip-rarity.SR { background: linear-gradient(135deg, #9B59B6, #8E44AD); color: #fff; }
    .tooltip-rarity.R { background: linear-gradient(135deg, #3498DB, #2980B9); color: #fff; }

    .tooltip-desc {
      font-size: 0.72rem;
      color: var(--text-secondary);
      line-height: 1.4;
    }

    /* ===== RESPONSIVE ===== */
    @media (max-width: 420px) {
      .player-bar { padding: 6px 8px; gap: 6px; }
      .player-name { font-size: 0.75rem; }
      .captured-piece { width: 18px; height: 18px; }
      .player-avatar { width: 30px; height: 30px; }
      .game-header { padding: 4px 8px; }
    }

    @media (min-height: 800px) {
      #game-screen { padding-top: 16px; }
      .player-bar { padding: 10px 14px; margin: 6px 0; }
    }

    /* ===== MOVE LOG ===== */
    .move-log {
      width: min(95vw, 580px);
      max-height: 90px;
      overflow-y: auto;
      margin-top: 8px;
      padding: 6px 10px;
      background: var(--bg-card);
      border-radius: 8px;
      border: 1px solid var(--board-border);
      font-size: 0.7rem;
      color: var(--text-secondary);
      display: flex;
      flex-wrap: wrap;
      gap: 2px 8px;
    }
    .move-entry { white-space: nowrap; }
    .move-num { color: var(--text-muted); margin-right: 2px; }
    .move-san { color: var(--text-primary); font-weight: 700; }
    .move-san.capture { color: var(--accent-pink); }
    .move-san.check { color: #E74C3C; }

    /* ===== SCROLLBAR ===== */
    ::-webkit-scrollbar { width: 4px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: var(--board-border); border-radius: 2px; }
  </style>
</head>
<body>

  <!-- ===== TITLE SCREEN ===== -->
  <div id="title-screen">
    <div class="title-bg"></div>
    <div class="stars" id="stars-container"></div>

    <div class="game-title">오타쿠 체스</div>
    <div class="title-sub">♰ CELESTIA vs ABYSSAL ♱</div>

    <div class="title-versus">
      <div class="faction-preview">
        <div class="faction-icon angel">♕</div>
        <div class="faction-label">천사 학원</div>
      </div>
      <div class="vs-text">VS</div>
      <div class="faction-preview">
        <div class="faction-icon demon">♛</div>
        <div class="faction-label">마계 학원</div>
      </div>
    </div>

    <div class="title-buttons">
      <button class="btn btn-primary" onclick="startGame('ai')">⚔️ AI 대전</button>
      <button class="btn" onclick="startGame('pvp')">👥 로컬 대전</button>
    </div>

    <div class="title-credit">OTAKU CHESS MVP v1.0</div>
  </div>

  <!-- ===== GAME SCREEN ===== -->
  <div id="game-screen">
    <div class="game-header">
      <div class="game-title-small">오타쿠 체스</div>
      <div class="header-btns">
        <button class="btn-icon" onclick="undoMove()" title="되돌리기">↩</button>
        <button class="btn-icon" onclick="goToTitle()" title="타이틀로">⌂</button>
      </div>
    </div>

    <div class="player-bar" id="bar-black">
      <div class="player-avatar" id="avatar-black"></div>
      <div class="player-info">
        <div class="player-name" id="name-black">마계 학원</div>
        <div class="player-faction" id="faction-black">ABYSSAL ACADEMY</div>
      </div>
      <div class="captured-row" id="captured-black"></div>
