/* ============================================================
   SOUND EFFECTS (Web Audio API)
============================================================ */
let audioCtx = null;

function initAudio() {
  if (!audioCtx) {
    try { audioCtx = new (window.AudioContext || window.webkitAudioContext)(); }
    catch (e) { /* Audio not supported */ }
  }
}

function playSound(type) {
  if (!audioCtx) return;
  try {
    const now = audioCtx.currentTime;
    const o = audioCtx.createOscillator();
    const g = audioCtx.createGain();
    o.connect(g); g.connect(audioCtx.destination);

    switch (type) {
      case 'move':
        o.type = 'sine'; o.frequency.value = 520;
        g.gain.setValueAtTime(0.07, now);
        g.gain.exponentialRampToValueAtTime(0.001, now + 0.08);
        o.start(now); o.stop(now + 0.08);
        break;
      case 'capture': {
        o.type = 'triangle'; o.frequency.value = 280;
        g.gain.setValueAtTime(0.1, now);
        g.gain.exponentialRampToValueAtTime(0.001, now + 0.18);
        o.start(now); o.stop(now + 0.18);
        const o2 = audioCtx.createOscillator();
        const g2 = audioCtx.createGain();
        o2.connect(g2); g2.connect(audioCtx.destination);
        o2.type = 'sine'; o2.frequency.value = 700;
        g2.gain.setValueAtTime(0.05, now);
        g2.gain.exponentialRampToValueAtTime(0.001, now + 0.15);
        o2.start(now + 0.02); o2.stop(now + 0.17);
        break;
      }
      case 'check':
        o.type = 'square';
        o.frequency.setValueAtTime(880, now);
        o.frequency.setValueAtTime(660, now + 0.1);
        o.frequency.setValueAtTime(880, now + 0.2);
        g.gain.setValueAtTime(0.06, now);
        g.gain.exponentialRampToValueAtTime(0.001, now + 0.3);
        o.start(now); o.stop(now + 0.3);
        break;
      case 'gameover': {
        [440, 554, 659, 880].forEach((freq, i) => {
          const oo = audioCtx.createOscillator();
          const gg = audioCtx.createGain();
          oo.connect(gg); gg.connect(audioCtx.destination);
          oo.type = 'sine'; oo.frequency.value = freq;
          gg.gain.setValueAtTime(0.06, now + i * 0.12);
          gg.gain.exponentialRampToValueAtTime(0.001, now + i * 0.12 + 0.3);
          oo.start(now + i * 0.12); oo.stop(now + i * 0.12 + 0.3);
        });
        break;
      }
      default:
        o.stop();
    }
  } catch (e) { /* Ignore audio errors */ }
}

/* ============================================================
   GAME STATE
============================================================ */
let game = null;
let gameMode = 'ai';
let selectedSquare = null;
let legalMovesForSelected = [];
let lastMove = null;
let isAIThinking = false;
let capturedByWhite = []; // black pieces captured by white
let capturedByBlack = []; // white pieces captured by black
let moveList = [];
let promotionPending = null;

/* ============================================================
   COORDINATE HELPERS
============================================================ */
function squareFromRC(row, col) {
  return String.fromCharCode(97 + col) + (8 - row);
}

function getPieceCode(piece) {
  if (!piece) return null;
  return (piece.color === 'w' ? 'w' : 'b') + piece.type.toUpperCase();
}

/* ============================================================
   BOARD RENDERING
============================================================ */
function renderBoard() {
  const boardEl = document.getElementById('board');
  boardEl.innerHTML = '';
  const boardData = game.board();
  const inCheck = game.in_check();
  const turn = game.turn();

  for (let row = 0; row < 8; row++) {
    for (let col = 0; col < 8; col++) {
      const sq = squareFromRC(row, col);
      const isLight = (row + col) % 2 === 0;
      const piece = boardData[row][col];
      const pieceCode = getPieceCode(piece);

      const div = document.createElement('div');
      div.className = `square ${isLight ? 'light' : 'dark-sq'}`;
      div.dataset.square = sq;

      // Last move highlight
      if (lastMove && (sq === lastMove.from || sq === lastMove.to)) {
        div.classList.add('last-move');
      }

      // Selected highlight
      if (sq === selectedSquare) {
        div.classList.add('selected');
      }

      // Legal move indicators
      if (legalMovesForSelected.some(m => m.to === sq)) {
        div.classList.add(piece ? 'legal-capture' : 'legal-move');
      }

      // Check highlight
      if (inCheck && piece && piece.type === 'k' && piece.color === turn) {
        div.classList.add('check-sq');
      }

      // Piece
      if (pieceCode && PIECE_SVGS[pieceCode]) {
        const pw = document.createElement('div');
        pw.className = 'piece-wrap';
        pw.innerHTML = PIECE_SVGS[pieceCode];
        div.appendChild(pw);
      }

      // Coordinate labels
      if (row === 7) {
        const fileLabel = document.createElement('span');
        fileLabel.className = 'coord-label coord-file';
        fileLabel.textContent = String.fromCharCode(97 + col);
        div.appendChild(fileLabel);
      }
      if (col === 0) {
        const rankLabel = document.createElement('span');
        rankLabel.className = 'coord-label coord-rank';
        rankLabel.textContent = 8 - row;
        div.appendChild(rankLabel);
      }

      // Click handler
      div.addEventListener('click', () => handleSquareClick(sq));

      // Tooltip on long press / hover
      div.addEventListener('mouseenter', (e) => {
        if (pieceCode) showTooltip(pieceCode, e.clientX, e.clientY);
      });
      div.addEventListener('mouseleave', hideTooltip);
      let longPressTimer = null;
      div.addEventListener('touchstart', (e) => {
        if (pieceCode) {
          longPressTimer = setTimeout(() => {
            const touch = e.touches[0];
            showTooltip(pieceCode, touch.clientX, touch.clientY);
          }, 400);
        }
      }, { passive: true });
      div.addEventListener('touchend', () => {
        clearTimeout(longPressTimer);
        hideTooltip();
      });

      boardEl.appendChild(div);
    }
  }
}

/* ============================================================
   CLICK HANDLING
============================================================ */
function handleSquareClick(sq) {
  if (isAIThinking) return;
  if (promotionPending) return;
  if (game.game_over()) return;

  initAudio();

  const piece = game.get(sq);
  const turn = game.turn();

  // If in AI mode and it's AI's turn, ignore clicks
  if (gameMode === 'ai' && turn === 'b') return;

  // If a square is already selected
  if (selectedSquare) {
    // Check if clicking a legal move target
    const targetMove = legalMovesForSelected.find(m => m.to === sq);
    if (targetMove) {
      // Check if promotion is needed
      if (targetMove.flags.includes('p') || (targetMove.piece === 'p' &&
          ((turn === 'w' && sq[1] === '8') || (turn === 'b' && sq[1] === '1')))) {
        // Check if any of the legal moves for this destination include promotion
        const promoMoves = legalMovesForSelected.filter(m => m.to === sq && m.promotion);
        if (promoMoves.length > 0) {
          showPromotionModal(selectedSquare, sq, turn);
          return;
        }
      }
      makeMove(selectedSquare, sq);
      return;
    }

    // If clicking own piece, reselect
    if (piece && piece.color === turn) {
      selectSquare(sq);
      return;
    }

    // Otherwise deselect
    deselectSquare();
    return;
  }

  // No square selected - select own piece
  if (piece && piece.color === turn) {
    selectSquare(sq);
  }
}

function selectSquare(sq) {
  selectedSquare = sq;
  legalMovesForSelected = game.moves({ square: sq, verbose: true });
  renderBoard();
}

function deselectSquare() {
  selectedSquare = null;
  legalMovesForSelected = [];
  renderBoard();
}

/* ============================================================
   MOVE EXECUTION
============================================================ */
function makeMove(from, to, promotion) {
  const moveObj = { from, to };
  if (promotion) moveObj.promotion = promotion;

  const result = game.move(moveObj);
  if (!result) return false;

  // Track captures
  if (result.captured) {
    const capturedCode = (result.color === 'w' ? 'b' : 'w') + result.captured.toUpperCase();
    if (result.color === 'w') {
      capturedByWhite.push(capturedCode);
    } else {
      capturedByBlack.push(capturedCode);
    }
    playSound('capture');
  } else {
    playSound('move');
  }

  if (game.in_check()) {
    playSound('check');
  }

  lastMove = { from: result.from, to: result.to };
  moveList.push(result.san);
  selectedSquare = null;
  legalMovesForSelected = [];

  renderBoard();
  updateUI();
  updateMoveLog();

  // Check game over
  if (game.game_over()) {
    setTimeout(() => showGameOver(), 500);
    return true;
  }

  // AI's turn
  if (gameMode === 'ai' && game.turn() === 'b') {
    isAIThinking = true;
    updateStatus();
    setTimeout(() => {
      makeAIMove();
    }, 600 + Math.random() * 500);
  }

  return true;
}

/* ============================================================
   AI
============================================================ */
const PIECE_VALUES = { p: 10, n: 30, b: 32, r: 50, q: 90, k: 900 };

// Position bonus tables (simplified)
const CENTER_BONUS = {};
['d4','d5','e4','e5'].forEach(s => CENTER_BONUS[s] = 8);
['c3','c4','c5','c6','d3','d6','e3','e6','f3','f4','f5','f6'].forEach(s => CENTER_BONUS[s] = 4);
['b2','b3','b4','b5','b6','b7','c2','c7','d2','d7','e2','e7','f2','f7','g2','g3','g4','g5','g6','g7'].forEach(s => CENTER_BONUS[s] = 2);

function evaluateBoard() {
  let score = 0;
  const board = game.board();
  for (let r = 0; r < 8; r++) {
    for (let c = 0; c < 8; c++) {
      const p = board[r][c];
      if (p) {
        const sq = squareFromRC(r, c);
        let val = PIECE_VALUES[p.type] || 0;
        val += (CENTER_BONUS[sq] || 0) * 0.3;
        score += p.color === 'w' ? val : -val;
      }
    }
  }
  return score;
}

function makeAIMove() {
  const moves = game.moves({ verbose: true });
  if (moves.length === 0) { isAIThinking = false; return; }

  let bestScore = Infinity;
  let bestMoves = [];

  for (const move of moves) {
    game.move(move);

    let score = evaluateBoard();

    // Bonus for checkmate
    if (game.in_checkmate()) score = -10000;
    else if (game.in_check()) score -= 15;
    // Penalty for stalemate
    if (game.in_stalemate()) score = 0;

    game.undo();

    // Random jitter
    score += (Math.random() - 0.5) * 6;

    if (score < bestScore) {
      bestScore = score;
      bestMoves = [move];
    } else if (Math.abs(score - bestScore) < 1) {
      bestMoves.push(move);
    }
  }

  const chosen = bestMoves[Math.floor(Math.random() * bestMoves.length)];

  // Track captures
  if (chosen.captured) {
    const capturedCode = 'w' + chosen.captured.toUpperCase();
    capturedByBlack.push(capturedCode);
  }

  const result = game.move(chosen);
  if (!result) { isAIThinking = false; return; }

  if (result.captured) {
    playSound('capture');
  } else {
    playSound('move');
  }
  if (game.in_check()) playSound('check');

  lastMove = { from: result.from, to: result.to };
  moveList.push(result.san);
  isAIThinking = false;

  renderBoard();
  updateUI();
  updateMoveLog();

  if (game.game_over()) {
    setTimeout(() => showGameOver(), 500);
  }
}

/* ============================================================
   PROMOTION
============================================================ */
function showPromotionModal(from, to, color) {
  promotionPending = { from, to, color };
  const grid = document.getElementById('promotion-grid');
  grid.innerHTML = '';
  const promoTypes = [
    { piece: 'q', label: '여왕' },
    { piece: 'r', label: '룩' },
    { piece: 'b', label: '비숍' },
    { piece: 'n', label: '나이트' }
  ];

  promoTypes.forEach(pt => {
    const code = color + pt.piece.toUpperCase();
    const opt = document.createElement('div');
    opt.className = 'promo-option';
    opt.innerHTML = `
      <div class="promo-avatar">${PIECE_SVGS[code] || ''}</div>
      <div class="promo-label">${CHARACTERS[code] ? CHARACTERS[code].name : pt.label}</div>
    `;
    opt.addEventListener('click', () => {
      document.getElementById('promotion-modal').classList.remove('active');
      makeMove(from, to, pt.piece);
      promotionPending = null;
    });
    grid.appendChild(opt);
  });

  document.getElementById('promotion-modal').classList.add('active');
}

/* ============================================================
   GAME OVER
============================================================ */
function showGameOver() {
  playSound('gameover');
  const modal = document.getElementById('gameover-modal');
  const title = document.getElementById('gameover-title');
  const msg = document.getElementById('gameover-msg');

  if (game.in_checkmate()) {
    const winner = game.turn() === 'w' ? '마계 학원' : '천사 학원';
    const loser = game.turn() === 'w' ? '천사 학원' : '마계 학원';
    title.textContent = '체크메이트!';
    msg.textContent = `${winner} 승리! ${loser}의 왕이 쓰러졌습니다.`;
  } else if (game.in_stalemate()) {
    title.textContent = '스테일메이트';
    msg.textContent = '무승부! 움직일 수 있는 기물이 없습니다.';
  } else if (game.in_draw()) {
    title.textContent = '무승부';
    msg.textContent = '게임이 무승부로 종료되었습니다.';
  } else if (game.in_threefold_repetition()) {
    title.textContent = '무승부';
    msg.textContent = '같은 국면이 3번 반복되어 무승부입니다.';
  } else {
    title.textContent = '게임 종료';
    msg.textContent = '게임이 종료되었습니다.';
  }

  modal.classList.add('active');
}

/* ============================================================
   UI UPDATES
============================================================ */
function updateUI() {
  const turn = game.turn();

  // Player bars
  const barW = document.getElementById('bar-white');
  const barB = document.getElementById('bar-black');
  const badgeW = document.getElementById('badge-white');
  const badgeB = document.getElementById('badge-black');

  barW.classList.toggle('active', turn === 'w');
  barB.classList.toggle('active', turn === 'b');
  badgeW.classList.toggle('hidden', turn !== 'w');
  badgeB.classList.toggle('hidden', turn !== 'b');

  // Captured pieces
  renderCaptured('captured-white', capturedByWhite);
  renderCaptured('captured-black', capturedByBlack);

  updateStatus();
}

function renderCaptured(elId, pieces) {
  const el = document.getElementById(elId);
  el.innerHTML = '';
  // Sort by value
  const order = { P: 0, N: 1, B: 2, R: 3, Q: 4 };
  const sorted = [...pieces].sort((a, b) => (order[a[1]] || 0) - (order[b[1]] || 0));
  sorted.forEach(code => {
    const div = document.createElement('div');
    div.className = 'captured-piece';
    div.innerHTML = PIECE_SVGS[code] || '';
    el.appendChild(div);
  });
}

function updateStatus() {
  const bar = document.getElementById('status-bar');
  if (game.game_over()) {
    bar.textContent = '게임 종료';
    return;
  }
  if (isAIThinking) {
    bar.innerHTML = '<span class="thinking">마계 학원 생각 중 <span class="thinking-dots"><span></span><span></span><span></span></span></span>';
    return;
  }
  if (game.in_check()) {
    bar.textContent = '⚠️ 체크!';
    return;
  }
  const turnText = game.turn() === 'w' ? '천사 학원' : '마계 학원';
  bar.textContent = `${turnText}의 차례`;
}

function updateMoveLog() {
  const log = document.getElementById('move-log');
  log.innerHTML = '';
  for (let i = 0; i < moveList.length; i += 2) {
    const num = Math.floor(i / 2) + 1;
    const w = moveList[i];
    const b = moveList[i + 1] || '';

    const entry = document.createElement('span');
    entry.className = 'move-entry';

    const isWCapture = w.includes('x');
    const isBCapture = b.includes('x');
    const isWCheck = w.includes('+') || w.includes('#');
    const isBCheck = b.includes('+') || b.includes('#');

    let html = `<span class="move-num">${num}.</span>`;
    html += `<span class="move-san${isWCapture ? ' capture' : ''}${isWCheck ? ' check' : ''}">${w}</span>`;
    if (b) {
      html += ` <span class="move-san${isBCapture ? ' capture' : ''}${isBCheck ? ' check' : ''}">${b}</span>`;
    }
    entry.innerHTML = html;
    log.appendChild(entry);
  }
  log.scrollTop = log.scrollHeight;
}

/* ============================================================
   TOOLTIP
============================================================ */
function showTooltip(code, x, y) {
  const c = CHARACTERS[code];
  if (!c) return;
  const tip = document.getElementById('char-tooltip');
  document.getElementById('tip-avatar').innerHTML = PIECE_SVGS[code] || '';
  document.getElementById('tip-name').textContent = c.name;
  const rarity = document.getElementById('tip-rarity');
  rarity.textContent = c.rarity;
  rarity.className = `tooltip-rarity ${c.rarity}`;
  document.getElementById('tip-desc').textContent = `[${c.roleKR}] ${c.desc}`;
  tip.classList.add('visible');

  // Position
  const pad = 12;
  let left = x + pad;
  let top = y + pad;
  if (left + 210 > window.innerWidth) left = x - 210;
  if (top + 120 > window.innerHeight) top = y - 120;
  tip.style.left = Math.max(4, left) + 'px';
  tip.style.top = Math.max(4, top) + 'px';
}

function hideTooltip() {
  document.getElementById('char-tooltip').classList.remove('visible');
}

/* ============================================================
   GAME FLOW
============================================================ */
function startGame(mode) {
  gameMode = mode;
  game = new Chess();
  selectedSquare = null;
  legalMovesForSelected = [];
  lastMove = null;
  isAIThinking = false;
  capturedByWhite = [];
  capturedByBlack = [];
  moveList = [];
  promotionPending = null;

  // Set player avatars
  document.getElementById('avatar-white').innerHTML = PIECE_SVGS['wK'];
  document.getElementById('avatar-black').innerHTML = PIECE_SVGS['bK'];

  if (mode === 'ai') {
    document.getElementById('name-black').textContent = '마계 학원 (AI)';
  } else {
    document.getElementById('name-black').textContent = '마계 학원';
  }

  document.getElementById('title-screen').style.display = 'none';
  document.getElementById('game-screen').style.display = 'flex';

  renderBoard();
  updateUI();
  updateMoveLog();
}

function resetGame() {
  document.getElementById('gameover-modal').classList.remove('active');
  document.getElementById('promotion-modal').classList.remove('active');
  startGame(gameMode);
}

function undoMove() {
  if (isAIThinking) return;
  if (moveList.length === 0) return;

  // In AI mode, undo two moves (player + AI)
  if (gameMode === 'ai' && game.turn() === 'w' && moveList.length >= 2) {
    // Undo AI move
    const aiResult = game.undo();
    if (aiResult && aiResult.captured) {
      capturedByBlack.pop();
    }
    moveList.pop();

    // Undo player move
    const playerResult = game.undo();
    if (playerResult && playerResult.captured) {
      capturedByWhite.pop();
    }
    moveList.pop();
  } else {
    const result = game.undo();
    if (result && result.captured) {
      if (result.color === 'w') capturedByWhite.pop();
      else capturedByBlack.pop();
    }
    moveList.pop();
  }

  selectedSquare = null;
  legalMovesForSelected = [];
  lastMove = moveList.length > 0 ? null : null; // Simplified - lose last move highlight on undo
  renderBoard();
  updateUI();
  updateMoveLog();
}

function goToTitle() {
  document.getElementById('gameover-modal').classList.remove('active');
  document.getElementById('promotion-modal').classList.remove('active');
  document.getElementById('game-screen').style.display = 'none';
  document.getElementById('title-screen').style.display = 'flex';
  isAIThinking = false;
}

/* ============================================================
   STARS ANIMATION
============================================================ */
function createStars() {
  const container = document.getElementById('stars-container');
  container.innerHTML = '';
  const count = 40;
  for (let i = 0; i < count; i++) {
    const star = document.createElement('div');
    star.className = 'star';
    star.style.left = Math.random() * 100 + '%';
    star.style.top = Math.random() * 100 + '%';
    star.style.animationDelay = (Math.random() * 3) + 's';
    star.style.animationDuration = (2 + Math.random() * 3) + 's';
    const size = 1.5 + Math.random() * 2.5;
    star.style.width = size + 'px';
    star.style.height = size + 'px';
    container.appendChild(star);
  }
}

/* ============================================================
   INIT
============================================================ */
function init() {
  createStars();

  // Verify chess.js loaded
  if (typeof Chess === 'undefined') {
    document.getElementById('title-screen').innerHTML =
      '<div style="text-align:center;padding:40px;color:var(--text-secondary)">' +
      '<p style="font-size:1.2rem;margin-bottom:12px">⚠️ 체스 엔진 로드 실패</p>' +
      '<p>새로고침 해주세요.</p></div>';
  }
}

init();
